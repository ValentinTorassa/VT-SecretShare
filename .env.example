# Copy to .env and load with `set -a; . ./.env; set +a` (or use docker-compose).
PORT=8080
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
# Public base URL used to build share links (set this when behind Tailscale/Nginx).
BASE_URL=http://localhost:8080
# Limits
MAX_CIPHERTEXT_BYTES=262144
DEFAULT_TTL_SECONDS=86400
MAX_TTL_SECONDS=604800
